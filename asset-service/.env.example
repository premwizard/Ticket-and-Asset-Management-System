# Asset Service — Environment Variables Example
# Copy this to .env and fill in the values

# Flask
FLASK_ENV=production
FLASK_DEBUG=0
FLASK_PORT=5002

# Database (Use DATABASE_URL for Render/Production)
# If DATABASE_URL is provided, separate DB_* variables are optional
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=asset_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# CORS
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173,http://localhost:3000
